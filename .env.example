# =============================================================================
# .env.example — RevitNavisResearcher MCP Server Configuration
# Copy to .env and fill in your values
# =============================================================================

# ===== RouterAI (required) =====
# Get your API key: https://routerai.ru/settings/keys
ROUTERAI_API_KEY=sk-your-api-key-here

# ===== RouterAI API (optional, defaults below) =====
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
EMBEDDING_MODEL=baai/bge-m3
LLM_MODEL=deepseek/deepseek-v4-flash

# ===== LLM Provider (routerai | ollama) =====
# Для локального использования без API-ключа укажите LLM_PROVIDER=ollama
LLM_PROVIDER=routerai

# ===== Ollama (локальный LLM, когда LLM_PROVIDER=ollama) =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b

# ===== Qdrant Vector Database =====
# For local Docker (via docker-compose): http://qdrant:6333
# For remote server: http://host:6333
QDRANT_URL=https://d9e0f9d73f7a.vps.myjino.ru:6333

# ===== MCP Transport =====
# "stdio" — for CLI / kilo integration (default)
# "sse"   — for Docker / HTTP mode
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
